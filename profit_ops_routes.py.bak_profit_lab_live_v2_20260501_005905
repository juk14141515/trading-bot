.label{color:var(--muted);font-size:14px;font-weight:700}.value{font-size:30px;font-weight:900;margin-top:10px}
.good{color:var(--green)}.bad{color:var(--red)}.blue{color:var(--blue)}.yellow{color:var(--yellow)}
