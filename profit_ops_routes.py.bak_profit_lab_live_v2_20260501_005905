
from flask import Blueprint, jsonify, render_template_string
from profit_ops_analytics import snapshot
from dashboard_safety_ui import rate_limit

bp=Blueprint("profit_ops",__name__)

@bp.route("/api/profit-ops")
@rate_limit(max_requests=180, window_seconds=60)
def api_profit_ops():
    return jsonify(snapshot())

@bp.route("/profit")
@bp.route("/profit/history")
def profit():
    return render_template_string("""
<!doctype html>
