:root {
  --bg:#050609;
  --side:#070a10;
  --card:#0d111a;
  --card2:#111827;
  --line:#263044;
  --text:#eef2ff;
  --muted:#a7afc3;
  --purple:#8b5cf6;
  --purple2:#a78bfa;
  --good:#8ee99a;
  --warn:#f5d04c;
  --bad:#ff6b7a;
}

* { box-sizing:border-box; }

body {
  margin:0;
  min-height:100vh;
  background:var(--bg);
  color:var(--text);
  font-family:Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.side {
  position:fixed;
  left:0;
  top:0;
  bottom:0;
  width:260px;
  padding:28px 22px;
  background:linear-gradient(180deg,#080b12,#050609);
  border-right:1px solid var(--line);
}

.brand {
  font-size:28px;
  font-weight:900;
  letter-spacing:-0.04em;
  margin-bottom:14px;
}

.brand span { color:var(--purple2); }

.sub {
  color:var(--muted);
  margin:0 0 28px;
  font-size:14px;
}

.side a {
  display:block;
  color:var(--text);
  text-decoration:none;
  padding:15px 16px;
  margin:8px 0;
  border-radius:14px;
  font-weight:800;
  border:1px solid transparent;
}

.side a:hover {
  background:#0d111a;
  border-color:var(--line);
}

.main {
  margin-left:260px;
  padding:36px;
  max-width:1600px;
}

.hero {
  display:flex;
  justify-content:space-between;
  gap:28px;
  align-items:center;
  background:linear-gradient(135deg,#111827,#0b1020);
  border:1px solid var(--line);
  border-radius:26px;
  padding:32px;
  margin-bottom:28px;
}

.eyebrow {
  color:var(--purple2);
  text-transform:uppercase;
  letter-spacing:.12em;
  font-size:13px;
  font-weight:900;
  margin-bottom:18px;
}

h1 {
  font-size:44px;
  line-height:1;
  margin:0 0 18px;
  letter-spacing:-0.04em;
}

h2 { margin:0 0 18px; font-size:26px; }
h3 { margin:0 0 18px; color:#dbe5ff; }

p { color:var(--muted); line-height:1.55; }
.muted { color:var(--muted); }

.hero-dog {
  min-width:280px;
  display:flex;
  align-items:center;
  gap:16px;
  background:rgba(255,255,255,.03);
  border:1px solid var(--line);
  border-radius:22px;
  padding:18px;
}

.dog-icon {
  width:72px;
  height:72px;
  display:grid;
  place-items:center;
  border-radius:20px;
  border:1px solid #53607a;
  font-size:32px;
}

.grid {
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:18px;
  margin-bottom:28px;
}

.split {
  display:grid;
  grid-template-columns:2fr 1.25fr;
  gap:18px;
  margin-bottom:28px;
}

.card {
  background:linear-gradient(180deg,var(--card),#090d15);
  border:1px solid var(--line);
  border-radius:22px;
  padding:24px;
  box-shadow:0 20px 70px rgba(0,0,0,.22);
}

.card:hover {
  border-color:#3a4663;
}

.highlight {
  border-left:4px solid var(--purple);
}

.metric .big {
  font-size:32px;
  font-weight:900;
  letter-spacing:-0.04em;
  margin:10px 0;
}

.small-big { font-size:24px !important; }

.readiness div {
  margin:14px 0;
  color:var(--muted);
}

.dot {
  width:11px;
  height:11px;
  display:inline-block;
  border-radius:999px;
  margin-right:10px;
}

.dot.good { background:var(--good); }
.dot.warn { background:var(--warn); }
.dot.risk { background:var(--bad); }

.summary-list li,
.card li {
  margin:10px 0;
  line-height:1.45;
}

.module-link {
  color:inherit;
  text-decoration:none;
  min-height:150px;
}

.module-link:hover {
  border-color:var(--purple);
}

.roadmap-grid {
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:16px;
}

.roadmap-grid div {
  background:rgba(255,255,255,.025);
  border:1px solid var(--line);
  border-radius:18px;
  padding:18px;
}

strong { color:var(--text); }

@media (max-width:1200px) {
  .grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
  .roadmap-grid { grid-template-columns:repeat(2,minmax(0,1fr)); }
}

@media (max-width:850px) {
  .side {
    position:relative;
    width:100%;
    border-right:none;
    border-bottom:1px solid var(--line);
  }

  .main {
    margin-left:0;
    padding:20px;
  }

  .hero,
  .split {
    grid-template-columns:1fr;
    display:grid;
  }

  .grid,
  .roadmap-grid {
    grid-template-columns:1fr;
  }

  h1 { font-size:36px; }
}
