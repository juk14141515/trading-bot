  window.__ponderCalmMotionV2 = true;

  const style = document.createElement("style");
  style.innerHTML = `
    .card, .metric-card, .panel, canvas {
      transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease, opacity .25s ease !important;
