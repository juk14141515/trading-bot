    panel.id = "ppSettingsPanel";
    panel.style.cssText = `
      display:none;
      position:fixed;
      right:22px;
      bottom:88px;
      z-index:100000;
      width:290px;
      padding:18px;
      border-radius:18px;
      border:1px solid rgba(140,160,255,.35);
      background:rgba(18,24,45,.96);
