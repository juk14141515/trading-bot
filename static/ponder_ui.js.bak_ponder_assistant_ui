/* === PonderAI Live Alert Toasts v1 === */
(function () {
  if (window.__ponderLiveAlertToastsV1) return;
  window.__ponderLiveAlertToastsV1 = true;

  if (window.location.pathname.includes("/login")) return;

  const style = document.createElement("style");
  style.innerHTML = `
    #ponderToastWrap {
      position: fixed;
      right: 24px;
      top: 92px;
      z-index: 1000001;
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 360px;
      pointer-events: none;
    }

    .ponder-toast {
      pointer-events: auto;
      background: rgba(7, 17, 31, .96);
      border: 1px solid #334155;
      color: #e5e7eb;
      border-radius: 16px;
      padding: 14px 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,.55);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      animation: ponderToastIn .25s ease;
    }

    .ponder-toast-critical {
      border-color: #fb7185;
    }

    .ponder-toast-warning {
      border-color: #facc15;
    }

    .ponder-toast-info {
      border-color: #60a5fa;
    }

    .ponder-toast-achievement {
      border-color: #86efac;
    }

    .ponder-toast-title {
      font-weight: 900;
      margin-bottom: 4px;
      font-size: 14px;
    }

    .ponder-toast-msg {
      color: #cbd5e1;
      font-size: 13px;
      line-height: 1.35;
    }

    .ponder-toast-close {
      float: right;
      background: transparent;
      color: #94a3b8;
      border: 0;
      cursor: pointer;
      font-size: 16px;
      margin-left: 10px;
    }

    @keyframes ponderToastIn {
      from { opacity: 0; transform: translateY(-8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  `;
  document.head.appendChild(style);

  const wrap = document.createElement("div");
  wrap.id = "ponderToastWrap";
  document.body.appendChild(wrap);

  function seenKey(key) {
    return "ponder_alert_seen_" + key;
  }

  function showToast(alert) {
    const key = alert.key || `${alert.level}:${alert.category}:${alert.title}:${alert.message}`;
    if (localStorage.getItem(seenKey(key))) return;

    localStorage.setItem(seenKey(key), "1");

    const el = document.createElement("div");
    el.className = `ponder-toast ponder-toast-${alert.level || "info"}`;

    const icon =
      alert.level === "critical" ? "🚨" :
      alert.level === "warning" ? "⚠️" :
      alert.level === "achievement" ? "🏆" :
      "🔔";

    el.innerHTML = `
      <button class="ponder-toast-close">×</button>
      <div class="ponder-toast-title">${icon} ${alert.title || "Ponder Alert"}</div>
      <div class="ponder-toast-msg">${alert.message || ""}</div>
    `;

    el.querySelector(".ponder-toast-close").onclick = () => el.remove();

    wrap.appendChild(el);

    setTimeout(() => {
      if (el && el.parentNode) el.remove();
    }, alert.level === "critical" ? 12000 : 8000);
  }

  async function pollAlerts() {
    try {
      const res = await fetch("/static/research/notifications_latest.json?ts=" + Date.now(), {
        cache: "no-store"
      });

      if (!res.ok) return;

      const data = await res.json();
      const alerts = data.alerts || [];

      alerts
        .filter(a => ["critical", "warning", "achievement"].includes(a.level))
        .slice(0, 5)
        .forEach(showToast);
    } catch (e) {}
  }

  setTimeout(pollAlerts, 1500);
  setInterval(pollAlerts, 60000);
})();

