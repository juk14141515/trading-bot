      color: #fff;
      min-width: 260px;
      font-size: 13px;
    ">
      <strong style="color:${color}">${alert.title}</strong><br/>
      <span style="opacity:0.8">${alert.message}</span>
    </div>
  `;

  document.body.appendChild(container);

  container.style.position = "fixed";
  container.style.top = "20px";
  container.style.right = "20px";
  container.style.zIndex = 9999;

  setTimeout(() => container.remove(), 6000);
}

function checkNewAlerts(d) {
  const alerts = (d.notifications && d.notifications.alerts) || [];
  if (!alerts.length) return;

  const latest = alerts[0];
  const key = latest.title + latest.message;

  if (lastAlertKey !== key) {
    lastAlertKey = key;
    showToast(latest);
  }
}

